{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ModuleSpec",
  "type": "object",
  "required": ["moduleName", "displayName", "fields"],
  "properties": {
    "moduleName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "permissions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "label"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-zA-Z0-9]*$"
          },
          "type": {
            "type": "string",
            "enum": ["string", "int", "bool", "datetime"]
          },
          "label": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

